# Lumina_Ant - Variables de Entorno
# Copia este archivo a .env y configura tus valores

# Aplicación
APP_NAME=Lumina_Ant
VERSION=1.0.0
DEBUG=True

# Base de Datos
# SQLite (recomendado para desarrollo)
DATABASE_URL=sqlite:///./lumina_ant.db

# Para migrar a MySQL en producción, usa:
# DATABASE_URL=mysql+pymysql://usuario:password@localhost/lumina_ant

# ── Proveedor de IA ──────────────────────────────────────────
# Opciones: "claude", "openai", "gemini"
# Descomenta el que quieras usar:
AI_PROVIDER=claude
# AI_PROVIDER=openai
# AI_PROVIDER=gemini

# ── API Keys (solo necesitas la del proveedor activo) ────────
# Claude — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=tu_api_key_aqui

# OpenAI (ChatGPT) — https://platform.openai.com/api-keys
# OPENAI_API_KEY=tu_api_key_aqui

# Google Gemini — https://aistudio.google.com/apikey
# GOOGLE_API_KEY=tu_api_key_aqui

# ── Modelos (opcional, se usan defaults razonables) ──────────
# CLAUDE_MODEL=claude-sonnet-4-5-20251001
# OPENAI_MODEL=gpt-4o
# GEMINI_MODEL=gemini-2.0-flash

# ── Google Sheets (opcional) ─────────────────────────────────
# Necesario para importar desde Google Sheets.
# Crea una API Key en https://console.cloud.google.com/ con la API de Google Sheets habilitada.
# La hoja debe ser pública o compartida como "Cualquiera con el enlace puede ver".
# GOOGLE_SHEETS_API_KEY=tu_api_key_aqui

# CORS - Orígenes permitidos (separados por coma)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
