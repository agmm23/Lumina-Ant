# Lumina_Ant - Variables de Entorno
# Copia este archivo a .env y configura tus valores

# Aplicación
APP_NAME=Lumina_Ant
VERSION=1.0.0
DEBUG=True

# Base de Datos
# SQLite (recomendado para desarrollo)
DATABASE_URL=sqlite:///./lumina_ant.db

# Para migrar a MySQL en producción, usa:
# DATABASE_URL=mysql+pymysql://usuario:password@localhost/lumina_ant

# API de Anthropic Claude
# Obtén tu API key en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=tu_api_key_aqui

# CORS - Orígenes permitidos (separados por coma)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
